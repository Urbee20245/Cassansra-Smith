# Rename this file to .env and fill in your Hostinger MySQL credentials.
# This file is read by api/config.php as a fallback when hPanel env vars
# are not available.  Keep .env out of git — it is in .gitignore.

DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
